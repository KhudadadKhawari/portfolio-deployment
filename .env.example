# Domain and SSL
DOMAIN=portfolio.seferyak.com
LETSENCRYPT_EMAIL=admin@seferyak.com
CERTBOT_STAGING=0

# Images pushed by GitHub Actions to Docker Hub
BACKEND_IMAGE=docker.io/khudadadkhawari/portfolio-backend:latest
FRONTEND_IMAGE=docker.io/khudadadkhawari/portfolio-frontend:latest

# PostgreSQL
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://portfolio:change-me-postgres-password@postgres:5432/portfolio

# Backend runtime
APP_ENV=production
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
BACKEND_CORS_ORIGINS=https://portfolio.seferyak.com

# MinIO, internal-only by default
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=portfolio-assets
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=https://portfolio.seferyak.com
MINIO_USE_SSL=false

# Optional Docker Hub login used by deploy.sh for authenticated pulls or rate limits
DOCKERHUB_USERNAME=YOUR_DOCKERHUB_USERNAME
DOCKERHUB_TOKEN=YOUR_DOCKERHUB_TOKEN

# Generic notification webhook used by CI/CD or deployment scripts
DEPLOY_WEBHOOK_URL=

# Backups
BACKUP_RETENTION_DAYS=14
